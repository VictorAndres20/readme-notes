##########################################################################
#
#      !!!! IMPORTANT ----> UPDATE YOUR NX APP NAME <---- IMPORTANT !!!!
#
#         THIS SHOULD BE MOVED TO THE ROOT OF THE MONOREPO PROJECT
#                      Don't forget `.dockerignore`
#
#                   You can create a `pre-build.sh` file
#                      at the root of nest application
#                   to execute on the server before build
#
# ```bash
# echo "Getting script dirname"
# SCRIPT_DIR=$(dirname "$0")
# sleep 1
# echo "Moving to script dir"
# cd "$SCRIPT_DIR" || exit
# sleep 1
# echo "Moving Docker files"
# cp Dockerfile ../../. && cp .dockerignore ../../.
# ```
#
#                      Then execute your build command
#
#
#########################################################################

#########################################################################
# Stage 1: Builder stage
FROM node:24.11.0-slim AS builder
WORKDIR /usr/src/app

# Copy root dependency management files
COPY package.json package.json
COPY package-lock.json package-lock.json

# Copy the entire monorepo source code (before npm ci so workspaces can link)
COPY . .

# Update npm to use 11.10.0 version
RUN npm install -g npm@11.10.0

# Install all dependencies (including dev dependencies for the build)
RUN npm ci --include=dev

# Build the '[nest-app]' application in production mode with NX
RUN npx nx build [nest-app] --prod

#########################################################################
# Stage 2: Production stage
# Lean image with only the build output and production dependencies.
FROM node:24.11.0-slim AS production
WORKDIR /usr/src/app
ENV NODE_ENV=production

# Copy npm configuration (if needed for private registries)
# Also bring security flags if you have them in .npmrc
COPY .npmrc .npmrc

# Update npm to use 11.10.0 version
RUN npm install -g npm@11.10.0

# Copy the build output (includes package.json generated by Nx)
COPY --from=builder /usr/src/app/apps/[nest-app]/dist ./dist

# Install only production dependencies from the Nx-generated package.json
RUN cd dist && npm install --omit=dev

# Set production env
COPY --from=builder /usr/src/app/apps/[nest-app]/.env.production .env

# Copy api assets
COPY --from=builder /usr/src/app/api-assets ./api-assets

# Expose the port your application runs on.
# EXPOSE 8000

CMD ["node", "dist/main"]
